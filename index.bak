<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover"/>
  <meta name="apple-mobile-web-app-capable" content="yes"/>
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
  <meta name="mobile-web-app-capable" content="yes"/>
  <meta name="theme-color" content="#6366f1"/>
  <title>나의 레슨일지</title>
  <link rel="apple-touch-icon" href="data:image/png;base64,"/>
  <link rel="icon" type="image/png" href="data:image/png;base64,"/>
  <link rel="manifest" href="data:application/json;base64,"/>
  <meta name="description" content="음악 레슨 선생님을 위한 학생 관리, 수업 기록, 일정 관리 앱. Google Drive 클라우드 동기화 지원."/>
  <meta property="og:title" content="나의 레슨일지"/>
  <meta property="og:description" content="음악 레슨 선생님을 위한 학생 관리 &amp; 수업 기록 앱"/>
  <meta property="og:url" content="https://limfrog.github.io/mylesson/"/>
  <script>
    (function(){
      var dark=localStorage.getItem('app_theme_dark')==='true';
      document.documentElement.setAttribute('data-theme',dark?'dark':'light');
      document.documentElement.style.background=dark?'#0f0f13':'#f7f7fb';
    })();
    var _isKo=navigator.language.startsWith('ko');
    document.title=_isKo?'나의 레슨일지':'My Lesson Diary';
    var _m=document.createElement('meta');_m.name='apple-mobile-web-app-title';_m.content=document.title;document.head.appendChild(_m);
  </script>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html,body{height:100%;font-family:'Noto Sans KR',-apple-system,sans-serif;-webkit-font-smoothing:antialiased}
    #root{min-height:100%}
    *{-webkit-text-size-adjust:100%}
    button{-webkit-appearance:none;cursor:pointer}
    input,textarea,select{-webkit-appearance:none}
    @media(max-width:767px){input,textarea,select{font-size:16px!important}}
    body{overscroll-behavior:none}

    :root {
      --bg:#f7f7fb; --surface:#ffffff; --surface2:#f9fafb; --surface3:#f3f4f6;
      --border:#f0f0f5; --border2:#e5e7eb;
      --text:#1f2937; --text-sub:#6b7280; --text-muted:#9ca3af;
      --accent:#6366f1; --accent-bg:#eef2ff;
      --input-bg:#fafafa; --input-border:#e5e7eb;
      --header-bg:linear-gradient(135deg,#6366f1 0%,#7c3aed 100%);
      --tab-bg:#ffffff; --tab-border:#f0f0f5;
      --card-bg:#ffffff; --card-border:#f0f0f5;
      --modal-bg:#ffffff; --overlay:rgba(15,15,35,0.6);
      --green:#10b981; --green-bg:#f0fdf4; --green-text:#065f46;
      --red:#ef4444; --red-bg:#fef2f2; --red-text:#b91c1c;
      --amber:#f59e0b; --amber-bg:#fffbeb; --amber-text:#92400e;
      --blue:#3b82f6; --blue-bg:#eff6ff; --blue-text:#1e40af;
      --purple-bg:#f5f3ff; --purple-text:#7c3aed;
      --drum-bg:#ffffff; --drum-hl:#eef2ff;
      --menu-bg:#ffffff; --menu-text:#1f2937;
      --scroll-thumb:rgba(0,0,0,0.15);
      --tab-active-color:#6366f1;
    }
    [data-theme="dark"] {
      --bg:#0f0f13; --surface:#1a1a24; --surface2:#22222f; --surface3:#2a2a3a;
      --border:#2e2e40; --border2:#3a3a50;
      --text:#e8e8f0; --text-sub:#9090b0; --text-muted:#555570;
      --accent:#818cf8; --accent-bg:#1e1e3a;
      --input-bg:#22222f; --input-border:#3a3a50;
      --header-bg:linear-gradient(135deg,#312e81 0%,#4c1d95 100%);
      --tab-bg:#1a1a24; --tab-border:#2e2e40;
      --card-bg:#1a1a24; --card-border:#2e2e40;
      --modal-bg:#1a1a24; --overlay:rgba(0,0,0,0.82);
      --green:#34d399; --green-bg:#042e1a; --green-text:#6ee7b7;
      --red:#f87171; --red-bg:#1f0a0a; --red-text:#fca5a5;
      --amber:#fbbf24; --amber-bg:#1c1202; --amber-text:#fde68a;
      --blue:#60a5fa; --blue-bg:#0c1829; --blue-text:#93c5fd;
      --purple-bg:#1e1232; --purple-text:#c4b5fd;
      --drum-bg:#1a1a24; --drum-hl:#1e1e3a;
      --menu-bg:#22222f; --menu-text:#e8e8f0;
      --scroll-thumb:rgba(255,255,255,0.1);
      --tab-active-color:#818cf8;
    }

    body,html{background:var(--bg)!important;color:var(--text)}
    .app-wrap{background:var(--bg);min-height:100vh}
    .app-header{background:var(--header-bg)!important;transition:none!important}
    .app-header *{transition:none!important}
    .app-tabbar{background:var(--tab-bg);border-bottom:1.5px solid var(--tab-border)}
    .app-tab{color:var(--text-muted);border-bottom:2.5px solid transparent}
    .app-tab.active{color:var(--tab-active-color);border-bottom-color:var(--tab-active-color)}
    .app-card{background:var(--card-bg);border:1.5px solid var(--card-border);box-shadow:0 2px 8px rgba(0,0,0,0.04);border-radius:16px}
    [data-theme="dark"] .app-card{box-shadow:0 2px 8px rgba(0,0,0,0.3)}
    .app-modal-inner{background:var(--modal-bg)!important;color:var(--text)!important;border:1px solid var(--border)}
    .app-menu{background:var(--menu-bg)!important;border:1px solid var(--border)!important}
    .app-menu-item{color:var(--menu-text)!important;border-bottom-color:var(--border)!important}
    .app-menu-item:hover{background:var(--surface2)!important}
    .app-input{background:var(--input-bg);border:1.5px solid var(--input-border);color:var(--text);border-radius:10px;width:100%;padding:10px 13px;font-size:14px;font-family:'Noto Sans KR',sans-serif;outline:none;box-sizing:border-box}
    .app-input::placeholder{color:var(--text-muted)}.app-input:focus{border-color:var(--accent);background:var(--surface)}
    .search-input{flex:1;padding:10px 14px;border-radius:12px;border:1.5px solid var(--input-border);font-size:14px;font-family:'Noto Sans KR',sans-serif;background:var(--surface);color:var(--text);outline:none}
    .search-input::placeholder{color:var(--text-muted)}.search-input:focus{border-color:var(--accent)}
    .syncbar-ok{background:var(--green-bg);border-bottom:1px solid rgba(16,185,129,0.3)}
    .syncbar-error{background:var(--red-bg);border-bottom:1px solid rgba(239,68,68,0.3)}
    .syncbar-syncing{background:var(--accent-bg);border-bottom:1px solid rgba(99,102,241,0.3)}
    .syncbar-idle{background:var(--surface2);border-bottom:1px solid var(--border)}
    .drum-container{background:var(--drum-bg);border:1.5px solid var(--accent-bg);border-radius:14px;overflow:hidden}
    [data-theme="dark"] .drum-container{border-color:var(--border2)}
    .drum-col{border-right:1px solid var(--border)}.drum-col:last-child{border-right:none}
    .drum-highlight{background:var(--drum-hl)!important}
    .cal-nav-btn{background:var(--surface3)!important;color:var(--text)!important}
    .badge-green{background:var(--green-bg);color:var(--green)}.badge-red{background:var(--red-bg);color:var(--red)}
    .badge-amber{background:var(--amber-bg);color:var(--amber)}.badge-blue{background:var(--blue-bg);color:var(--blue)}
    .badge-accent{background:var(--accent-bg);color:var(--accent)}
    .t-text-muted{color:var(--text-muted)!important}
    ::-webkit-scrollbar{width:4px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--scroll-thumb);border-radius:4px}
    @keyframes sbaspin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
    *,*::before,*::after{transition:background-color 0.2s,border-color 0.2s,color 0.15s}
    .app-header,.app-header *{transition:none!important}
    #lock-bg-inner,#lock-bg-inner *,#lock-bg-content,#lock-bg-content *{transition:none!important}

    /* ── 반응형 레이아웃 ── */
    /* 태블릿: 768px 이상 — 사이드바 + 콘텐츠 */
    @media(min-width:768px){
      body{display:flex;justify-content:center}
      .app-wrap{width:100%;max-width:100%!important;display:grid;grid-template-rows:auto auto 1fr;min-height:100vh}
      .app-header{grid-column:1/-1}
      .app-tabbar{display:none!important}
      .app-body{display:flex;flex:1;min-height:0}
      .app-sidebar{width:200px;flex-shrink:0;border-right:1.5px solid var(--tab-border);background:var(--tab-bg);display:flex;flex-direction:column;padding:16px 8px;gap:4px;position:sticky;top:0;height:100vh;overflow-y:auto}
      .app-sidebar-btn{display:flex;align-items:center;gap:10px;padding:11px 14px;border-radius:12px;border:none;background:transparent;cursor:pointer;font-size:14px;font-weight:600;font-family:'Noto Sans KR',sans-serif;color:var(--text-muted);width:100%;text-align:left;transition:all 0.15s}
      .app-sidebar-btn.active{background:var(--accent-bg);color:var(--accent);font-weight:800}
      .app-sidebar-btn:hover:not(.active){background:var(--surface2)}
      .app-content{flex:1;overflow-y:auto;padding:24px 24px 80px}
      .app-content-inner{max-width:900px;margin:0 auto}
      .student-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
      .student-grid-wide{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px}
    }
    /* 데스크톱: 1200px 이상 — 3열 */
    @media(min-width:1200px){
      .app-sidebar{width:220px}
      .app-content{padding:28px 32px 80px}
      .app-content-inner{max-width:1400px}
      .student-grid{grid-template-columns:1fr 1fr 1fr}
      .student-grid-wide{grid-template-columns:repeat(4,1fr)}
    }
    /* 모바일: 하단 탭바 유지 */
    @media(max-width:767px){
      .app-sidebar{display:none}
      .app-body{display:block}
      .app-content{padding:0}
      .app-content-inner{padding:0}
      .student-grid,.student-grid-wide{display:flex;flex-direction:column;gap:inherit}
    }
  </style>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;700;900&display=swap" rel="stylesheet"/>
</head>
<body>
  <!-- 랜딩 페이지 (크롤러 인식 + JS 로딩 전 사용자에게 표시) -->
  <!-- React 마운트 시 #root 내부가 앱으로 교체됨 -->
  <div id="root">
    <div style="min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;background:#f7f7fb;font-family:'Noto Sans KR',sans-serif;padding:40px 20px;">
      <div style="background:#fff;border-radius:24px;padding:48px 36px;max-width:440px;width:100%;box-shadow:0 8px 40px rgba(99,102,241,0.13);text-align:center;">
        <img src="https://limfrog.github.io/mylesson/logo.png" alt="나의 레슨일지 로고" style="width:88px;height:88px;border-radius:22px;margin:0 auto 20px;display:block;"/>
        <h1 style="font-size:26px;font-weight:900;color:#1f2937;margin-bottom:8px;letter-spacing:-0.5px;">나의 레슨일지</h1>
        <p style="font-size:14px;color:#6b7280;margin-bottom:28px;line-height:1.7;">선생님을 위한 학생 관리 &amp; 수업 기록 앱<br/>Google Drive 자동 동기화 · Google Calendar 연동</p>
        <p style="font-size:13px;color:#9ca3af;margin-bottom:28px;">앱을 불러오는 중...</p>
        <nav style="padding-top:20px;border-top:1px solid #f0f0f5;display:flex;gap:20px;justify-content:center;">
          <a href="https://limfrog.github.io/mylesson/privacy.html" style="font-size:13px;color:#6366f1;text-decoration:none;font-weight:700;">개인정보처리방침</a>
          <a href="https://limfrog.github.io/mylesson/terms.html" style="font-size:13px;color:#6366f1;text-decoration:none;font-weight:700;">서비스 이용약관</a>
        </nav>
      </div>
    </div>
  </div>

